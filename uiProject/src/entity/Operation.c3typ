/**
 * Operation.c3typ
 *
 * Describes a mission/training/test flight including aircraft, bases, timing, status, and related alerts.
 */

entity type Operation {
  aircraft: Aircraft

  description: string enum("Mission", "Training", "Test")

  startDate: datetime

  endDate: datetime

  alerts: [OperationAlert](operation)

  status: string enum("Planned", "In Progress", "Completed")

  origin: Base

  destination: Base
}
