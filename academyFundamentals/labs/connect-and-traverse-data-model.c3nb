t\t\t},","\t\t\t\t\t\"cells\": [","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"store_003\",","\t\t\t\t\t\t\t\"source\": \"store_003\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"37.7609\",","\t\t\t\t\t\t\t\"source\": 37.7609","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"-122.435\",","\t\t\t\t\t\t\t\"source\": -122.435","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"city_001\",","\t\t\t\t\t\t\t\"source\": \"city_001\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"789 Castro St\",","\t\t\t\t\t\t\t\"source\": \"789 Castro St\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"{…}\",","\t\t\t\t\t\t\t\"source\": {","\t\t\t\t\t\t\t\t\"appCode\": 1865745090558541600,","\t\t\t\t\t\t\t\t\"env\": \"srinat\",","\t\t\t\t\t\t\t\t\"app\": \"academyfundamentals\",","\t\t\t\t\t\t\t\t\"created\": \"2026-05-21T20:32:18Z\",","\t\t\t\t\t\t\t\t\"createdBy\": \"provisioner\",","\t\t\t\t\t\t\t\t\"updated\": \"2026-05-21T20:48:10Z\",","\t\t\t\t\t\t\t\t\"updatedBy\": \"provisioner\",","\t\t\t\t\t\t\t\t\"timestamp\": \"2026-05-21T20:48:10Z\",","\t\t\t\t\t\t\t\t\"fetchInclude\": \"[]\",","\t\t\t\t\t\t\t\t\"fetchType\": \"Store\"","\t\t\t\t\t\t\t}","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"2\",","\t\t\t\t\t\t\t\"source\": 2","\t\t\t\t\t\t}","\t\t\t\t\t]","\t\t\t\t}","\t\t\t],","\t\t\t\"isDataGridValues\": false","\t\t}","\t},","\t\"settings\": {","\t\t\"privateFields\": false,","\t\t\"maxHeight\": 540,","\t\t\"gridRows\": 100,","\t\t\"theme\": \"Default Dark Modern\"","\t}","}"]}]}],"executionSummary":{"timing":{"startTime":1779396496675,"endTime":1779396502255},"executionOrder":7,"success":true}},{"kind":1,"languageId":"markdown","value":"**Expected output**\n\nYou should expect to see the records for `store_001`, `store_002`, and `store_003`.","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"## Section 2: Collection fields","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"A collection field is a field that can hold multiple values. To model a one-to-many relationship, you use collection fields along with reference fields. Collection fields can be an array, set, map, or a stream. In this lab, we will focus on array collection fields.\n\n\n<div class=\"alert alert-warning\">\n    The values in a collection field must share the same type.\n</div>\n\nLet's examine an example of a collection field definition. The following code snippet defines a `bulbs` collection field on the Fixture Type. \n\n```javascript\n// Example 1\nentity type Fixture {\n\n    /**\n     * The smart bulbs in the fixture.\n     */\n    bulbs: [SmartBulb]\n    \n}\n```\n\nIn this field definition, the notation `[...]` indicates that the field contains an array of references to the `SmartBulb` Type. While this is correct syntax, this definition says each `Fixture` in our application contains a reference to any smart bulb in our application. This is incorrect if this should represent the smart bulbs in their respective fixture. ","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"<div class=\"alert alert-info\">\n<h4>Activity 2.1</h4>\nCreate the collection field <code>City.stores</code>, which contains an array of <code>Store</code>s. Only use the square brackets syntax (<code>[...]</code>) for this activity.\n</div>","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"After you complete the activity, run the following cells to check.","output":[],"executionSummary":{}},{"kind":2,"languageId":"javascript","value":"// Note: You should only see an ID returned, not the stores\nCity.fetch({filter: Filter.eq('id', 'city_001'), include: '[id, stores]'}).objs","output":[{"items":[{"mime":"c3/notebook","value":["{","\t\"kind\": \"JSON\",","\t\"output\": {","\t\t\"data\": [","\t\t\t{","\t\t\t\t\"id\": \"city_001\",","\t\t\t\t\"meta\": {","\t\t\t\t\t\"fetchInclude\": \"[id,stores,version]\",","\t\t\t\t\t\"fetchType\": \"City\"","\t\t\t\t},","\t\t\t\t\"version\": 1","\t\t\t}","\t\t],","\t\t\"isGriddable\": true,","\t\t\"isChartable\": false,","\t\t\"chartMeta\": null,","\t\t\"gridMeta\": {","\t\t\t\"columns\": [","\t\t\t\t{","\t\t\t\t\t\"index\": 0,","\t\t\t\t\t\"label\": \"id\",","\t\t\t\t\t\"valueType\": {","\t\t\t\t\t\t\"modifier\": \"NON_EMPTY\",","\t\t\t\t\t\t\"name\": \"string\"","\t\t\t\t\t},","\t\t\t\t\t\"name\": \"id\"","\t\t\t\t},","\t\t\t\t{","\t\t\t\t\t\"index\": 1,","\t\t\t\t\t\"label\": \"meta.fetchInclude\",","\t\t\t\t\t\"valueType\": {","\t\t\t\t\t\t\"name\": \"string\"","\t\t\t\t\t},","\t\t\t\t\t\"name\": \"meta.fetchInclude\"","\t\t\t\t},","\t\t\t\t{","\t\t\t\t\t\"index\": 2,","\t\t\t\t\t\"label\": \"meta.fetchType\",","\t\t\t\t\t\"valueType\": {","\t\t\t\t\t\t\"name\": \"string\"","\t\t\t\t\t},","\t\t\t\t\t\"name\": \"meta.fetchType\"","\t\t\t\t},","\t\t\t\t{","\t\t\t\t\t\"index\": 3,","\t\t\t\t\t\"label\": \"version\",","\t\t\t\t\t\"valueType\": {","\t\t\t\t\t\t\"name\": \"int32\"","\t\t\t\t\t},","\t\t\t\t\t\"name\": \"version\"","\t\t\t\t}","\t\t\t],","\t\t\t\"rows\": [","\t\t\t\t{","\t\t\t\t\t\"index\": 0,","\t\t\t\t\t\"label\": \"0\",","\t\t\t\t\t\"labelSource\": 0,","\t\t\t\t\t\"source\": {","\t\t\t\t\t\t\"type\": \"City\",","\t\t\t\t\t\t\"id\": \"city_001\",","\t\t\t\t\t\t\"meta\": {","\t\t\t\t\t\t\t\"fetchInclude\": \"[id,stores,version]\",","\t\t\t\t\t\t\t\"fetchType\": \"City\"","\t\t\t\t\t\t},","\t\t\t\t\t\t\"version\": 1","\t\t\t\t\t},","\t\t\t\t\t\"cells\": [","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"city_001\",","\t\t\t\t\t\t\t\"source\": \"city_001\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"[id,stores,version]\",","\t\t\t\t\t\t\t\"source\": \"[id,stores,version]\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"City\",","\t\t\t\t\t\t\t\"source\": \"City\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"1\",","\t\t\t\t\t\t\t\"source\": 1","\t\t\t\t\t\t}","\t\t\t\t\t]","\t\t\t\t}","\t\t\t],","\t\t\t\"isDataGridValues\": false","\t\t}","\t},","\t\"settings\": {","\t\t\"privateFields\": false,","\t\t\"maxHeight\": 540,","\t\t\"gridRows\": 100,","\t\t\"theme\": \"Default Dark Modern\"","\t}","}"]}]}],"executionSummary":{"timing":{"startTime":1779396766930,"endTime":1779396767683},"executionOrder":9,"success":true}},{"kind":1,"languageId":"markdown","value":"If you see nothing for the `stores` field in the fetch result, this is expected. You can double check this by examining the data file `academyFundamentals/data/City/City.csv`, where the stores column is missing from the CSV.  This indicates that a generic `[SomeType]` collection field must be created at runtime in JavaScript.\n\nTo illustrate the collection field, we can create a toy city record that passes in a list of `Store` objects. Run the following cell and examine the output.","output":[],"executionSummary":{}},{"kind":2,"languageId":"javascript","value":"stores_list = [\n    Store.make({id: 'store_111'}), \n    Store.make({id: 'store_222'})\n]\n\n\n// Note: The instance is only created in memory.\n// The output should have  a list of stores.\nCity.make({\n    id: 'chicago', \n    stores: stores_list\n})","output":[{"items":[{"mime":"c3/notebook","value":["{","\t\"kind\": \"JSON\",","\t\"output\": {","\t\t\"data\": {","\t\t\t\"id\": \"chicago\"","\t\t},","\t\t\"isGriddable\": false,","\t\t\"isChartable\": false,","\t\t\"chartMeta\": null","\t},","\t\"settings\": {","\t\t\"privateFields\": false,","\t\t\"maxHeight\": 540,","\t\t\"gridRows\": 100,","\t\t\"theme\": \"Default Dark Modern\"","\t}","}"]}]}],"executionSummary":{"timing":{"startTime":1779396790939,"endTime":1779396791476},"executionOrder":10,"success":true}},{"kind":1,"languageId":"markdown","value":"What if we wanted to model our data so that the `stores` field contains the stores that are in that particular city? Luckily, there is a solution here. Instead of creating records on the fly for each record, you can leverage foreign key filters on collection fields, which uses the reference fields defined on other Types.\n\nIf you recall the <code>SmartBulb</code> Type definition in [Section 1](#section-1-create-reference-fields), the reference field `fixture` indicates which fixture the bulb is in. This foreign key field can be used to filter for the smart bulbs that are in a specific fixture. \n\nThis is shown in the following code snippet, with the `(...)` syntax added. In the parentheses, you specify the field on the collection field Type to use as the foreign key filter. In this example, the foreign key filter is the `SmartBulb.fixture` field.\n\n```javascript\n// Example 2\nentity type Fixture {\n\n    /**\n     * The smart bulbs in the fixture.\n     */\n    bulbs: [SmartBulb](fixture) // use the SmartBulb.fixture field as the foreign key\n    \n}\n```\n\nWhen you add `(fixture)`, the `SmartBulb` objects returned should only include the smart bulbs that are present in that specific fixture. The following graphic illustrates what the collection field on Fixture may look like based on the reference fields in SmartBulb.\n\n\n<img src=\"../src/doc/img/lab2/lab-2-connect-and-traverse-data-model.png\" alt=\"Graphic explaining collection fields with a foreign key filter.\" width=\"600px\" style=\"padding: inherit;\n  margin:auto; display:block;\"/> \n","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"<div class=\"alert alert-info\">\n<h4>Activity 2.2</h4>\n\nFix <code>City.stores</code> by adding a foreign key filter in the collection field declaration. The foreign key filter should be a field on the <code>Store</code> Type.\n</div>","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"<div class=\"alert alert-warning\">\n<b>Note:</b> You may have to restart your notebook to refresh the Types in the notebook. To do this, select <b>Restart</b> in the toolbar.\n</div>","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"##### Test your implementation","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"After you complete the activity, run the same code you did for Activity 2.1. This returns the list of stores found in a city.","output":[],"executionSummary":{}},{"kind":2,"languageId":"javascript","value":"// We use the `include` option to fetch the `stores` field. By default, only primitive fields are fetched.\nCity.fetch({filter: Filter.eq('id', 'city_001'), include: '[id, stores]'}).objs","output":[{"items":[{"mime":"c3/notebook","value":["{","\t\"kind\": \"JSON\",","\t\"output\": {","\t\t\"data\": [","\t\t\t{","\t\t\t\t\"id\": \"city_001\",","\t\t\t\t\"meta\": {","\t\t\t\t\t\"fetchInclude\": \"[id,{stores:[id]},version]\",","\t\t\t\t\t\"fetchType\": \"City\"","\t\t\t\t},","\t\t\t\t\"version\": 1","\t\t\t}","\t\t],","\t\t\"isGriddable\": true,","\t\t\"isChartable\": false,","\t\t\"chartMeta\": null,","\t\t\"gridMeta\": {","\t\t\t\"columns\": [","\t\t\t\t{","\t\t\t\t\t\"index\": 0,","\t\t\t\t\t\"label\": \"id\",","\t\t\t\t\t\"valueType\": {","\t\t\t\t\t\t\"modifier\": \"NON_EMPTY\",","\t\t\t\t\t\t\"name\": \"string\"","\t\t\t\t\t},","\t\t\t\t\t\"name\": \"id\"","\t\t\t\t},","\t\t\t\t{","\t\t\t\t\t\"index\": 1,","\t\t\t\t\t\"label\": \"meta.fetchInclude\",","\t\t\t\t\t\"valueType\": {","\t\t\t\t\t\t\"name\": \"string\"","\t\t\t\t\t},","\t\t\t\t\t\"name\": \"meta.fetchInclude\"","\t\t\t\t},","\t\t\t\t{","\t\t\t\t\t\"index\": 2,","\t\t\t\t\t\"label\": \"meta.fetchType\",","\t\t\t\t\t\"valueType\": {","\t\t\t\t\t\t\"name\": \"string\"","\t\t\t\t\t},","\t\t\t\t\t\"name\": \"meta.fetchType\"","\t\t\t\t},","\t\t\t\t{","\t\t\t\t\t\"index\": 3,","\t\t\t\t\t\"label\": \"version\",","\t\t\t\t\t\"valueType\": {","\t\t\t\t\t\t\"name\": \"int32\"","\t\t\t\t\t},","\t\t\t\t\t\"name\": \"version\"","\t\t\t\t}","\t\t\t],","\t\t\t\"rows\": [","\t\t\t\t{","\t\t\t\t\t\"index\": 0,","\t\t\t\t\t\"label\": \"0\",","\t\t\t\t\t\"labelSource\": 0,","\t\t\t\t\t\"source\": {","\t\t\t\t\t\t\"type\": \"City\",","\t\t\t\t\t\t\"id\": \"city_001\",","\t\t\t\t\t\t\"meta\": {","\t\t\t\t\t\t\t\"fetchInclude\": \"[id,{stores:[id]},version]\",","\t\t\t\t\t\t\t\"fetchType\": \"City\"","\t\t\t\t\t\t},","\t\t\t\t\t\t\"version\": 1","\t\t\t\t\t},","\t\t\t\t\t\"cells\": [","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"city_001\",","\t\t\t\t\t\t\t\"source\": \"city_001\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"[id,{stores:[id]},version]\",","\t\t\t\t\t\t\t\"source\": \"[id,{stores:[id]},version]\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"City\",","\t\t\t\t\t\t\t\"source\": \"City\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"1\",","\t\t\t\t\t\t\t\"source\": 1","\t\t\t\t\t\t}","\t\t\t\t\t]","\t\t\t\t}","\t\t\t],","\t\t\t\"isDataGridValues\": false","\t\t}","\t},","\t\"settings\": {","\t\t\"privateFields\": false,","\t\t\"maxHeight\": 540,","\t\t\"gridRows\": 100,","\t\t\"theme\": \"Default Dark Modern\"","\t}","}"]}]}],"executionSummary":{"timing":{"startTime":1779396928589,"endTime":1779396929493},"executionOrder":13,"success":true}},{"kind":1,"languageId":"markdown","value":"**Expected output**\n\nFor `city_001`, you should see the Store records `store_001`, `store_002`, and `store_003` in the `stores` field. You may have to expand the `stores` field in the output.","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"<div class=\"alert alert-info\">\n<h4>Activity 2.3</h4>\n\nCreate the following collection fields for the Types in your data model:\n<ul>\n<li><code>Sale.itemization</code>: a collection of <code>LineItem</code> records with this sale.</li>\n<li><code>Product.sales</code>: a collection of <code>LineItem</code> records that include this product.</li>\n<li><code>Store.sales</code>: a collection of <code>Sale</code> transactions made at the store.</li>\n</ul>\n\n</div>","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"##### Test your implementation","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"Test your implementation by running the following cells. Try restarting the notebook if the collection fields in the outputs are empty.","output":[],"executionSummary":{}},{"kind":1,"languageId":"markdown","value":"**Case 1: Sale**","output":[],"executionSummary":{}},{"kind":2,"languageId":"javascript","value":"Sale.fetch({include: \"[id, itemization]\", limit: 1}).objs","output":[{"items":[{"mime":"c3/notebook","value":["{","\t\"kind\": \"JSON\",","\t\"output\": {","\t\t\"data\": [","\t\t\t{","\t\t\t\t\"id\": \"sale_001\",","\t\t\t\t\"meta\": {","\t\t\t\t\t\"fetchInclude\": \"[id,{itemization:[id]},version]\",","\t\t\t\t\t\"fetchType\": \"Sale\"","\t\t\t\t},","\t\t\t\t\"version\": 2,","\t\t\t\t\"itemization\": [","\t\t\t\t\t{","\t\t\t\t\t\t\"id\": \"line_001\",","\t\t\t\t\t\t\"meta\": {","\t\t\t\t\t\t\t\"fetchInclude\": \"[id,sale,version]\",","\t\t\t\t\t\t\t\"fetchType\": \"LineItem\"","\t\t\t\t\t\t},","\t\t\t\t\t\t\"version\": 2,","\t\t\t\t\t\t\"sale\": {","\t\t\t\t\t\t\t\"id\": \"sale_001\"","\t\t\t\t\t\t}","\t\t\t\t\t},","\t\t\t\t\t{","\t\t\t\t\t\t\"id\": \"line_002\",","\t\t\t\t\t\t\"meta\": {","\t\t\t\t\t\t\t\"fetchInclude\": \"[id,sale,version]\",","\t\t\t\t\t\t\t\"fetchType\": \"LineItem\"","\t\t\t\t\t\t},","\t\t\t\t\t\t\"version\": 2,","\t\t\t\t\t\t\"sale\": {","\t\t\t\t\t\t\t\"id\": \"sale_001\"","\t\t\t\t\t\t}","\t\t\t\t\t}","\t\t\t\t]","\t\t\t}","\t\t],","\t\t\"isGriddable\": true,","\t\t\"isChartable\": false,","\t\t\"chartMeta\": null,","\t\t\"gridMeta\": {","\t\t\t\"columns\": [","\t\t\t\t{","\t\t\t\t\t\"index\": 0,","\t\t\t\t\t\"label\": \"id\",","\t\t\t\t\t\"valueType\": {","\t\t\t\t\t\t\"modifier\": \"NON_EMPTY\",","\t\t\t\t\t\t\"name\": \"string\"","\t\t\t\t\t},","\t\t\t\t\t\"name\": \"id\"","\t\t\t\t},","\t\t\t\t{","\t\t\t\t\t\"index\": 1,","\t\t\t\t\t\"label\": \"itemization\",","\t\t\t\t\t\"valueType\": {","\t\t\t\t\t\t\"elemen