 write a dot notation expression in the <code>include</code> field so that the fetch query returns the <code>LineItem</code> information along with the unit price of the product.\n</div>\n","output":[],"executionSummary":{}},{"kind":2,"languageId":"javascript","value":"// `include` requires a list of the fields on the Type to return.\n// Note: `this` returns all of the fields on the Type. In this case, it returns all of the fields on the LineItem Type.\n// TODO: Replace the `...` with the dot notation expression.\nLineItem.fetch({include: '[this, product.unitPrice]'})","output":[{"items":[{"mime":"c3/notebook","value":["{","\t\"kind\": \"JSON\",","\t\"output\": {","\t\t\"data\": {","\t\t\t\"objs\": [","\t\t\t\t{","\t\t\t\t\t\"id\": \"line_001\",","\t\t\t\t\t\"meta\": {","\t\t\t\t\t\t\"appCode\": 1865745090558541600,","\t\t\t\t\t\t\"env\": \"srinat\",","\t\t\t\t\t\t\"app\": \"academyfundamentals\",","\t\t\t\t\t\t\"created\": \"2026-05-21T20:32:18Z\",","\t\t\t\t\t\t\"createdBy\": \"provisioner\",","\t\t\t\t\t\t\"updated\": \"2026-05-21T20:48:11Z\",","\t\t\t\t\t\t\"updatedBy\": \"provisioner\",","\t\t\t\t\t\t\"timestamp\": \"2026-05-21T20:48:11Z\",","\t\t\t\t\t\t\"fetchInclude\": \"[this,{product:[unitPrice,id]}]\",","\t\t\t\t\t\t\"fetchType\": \"LineItem\"","\t\t\t\t\t},","\t\t\t\t\t\"version\": 2,","\t\t\t\t\t\"sale\": {","\t\t\t\t\t\t\"id\": \"sale_001\"","\t\t\t\t\t},","\t\t\t\t\t\"quantity\": 1,","\t\t\t\t\t\"price\": 129.99,","\t\t\t\t\t\"product\": {","\t\t\t\t\t\t\"id\": \"prod_001\",","\t\t\t\t\t\t\"unitPrice\": 129.99","\t\t\t\t\t}","\t\t\t\t},","\t\t\t\t{","\t\t\t\t\t\"id\": \"line_002\",","\t\t\t\t\t\"meta\": {","\t\t\t\t\t\t\"appCode\": 1865745090558541600,","\t\t\t\t\t\t\"env\": \"srinat\",","\t\t\t\t\t\t\"app\": \"academyfundamentals\",","\t\t\t\t\t\t\"created\": \"2026-05-21T20:32:18Z\",","\t\t\t\t\t\t\"createdBy\": \"provisioner\",","\t\t\t\t\t\t\"updated\": \"2026-05-21T20:48:11Z\",","\t\t\t\t\t\t\"updatedBy\": \"provisioner\",","\t\t\t\t\t\t\"timesta