"\t\t\"theme\": \"Default Dark Modern\"","\t}","}"]}]}],"executionSummary":{"timing":{"startTime":1779389790425,"endTime":1779389791099},"executionOrder":41,"success":true}},{"kind":2,"languageId":"javascript","value":"// Iterate through the products and update the price based on the category.\nvar tempPrice = 0;\n\nfor (i = 0; i < sale_products.length; i++) {\n    product = sale_products[i];\n\n    // TODO: Update the price of the product based on its category\n    // Hint: Use an if/else statement to check the category, and access the `unitPrice` field to update the price.\n    if (product.category == \"Clothing\") {\n\n        tempPrice = product.unitPrice * 0.75\n        \n    }\n\n    else {\n        tempPrice = product.unitPrice * 0.6\n    }\n\n    // TODO: Persist the changes. \n    // Hint: Access the `id` field of the product and use .make({...}) to create the updated Product object.\n    Product.make({\n        id: product.id, \n        unitPrice: tempPrice\n    }).merge()\n    \n}\n\n// Display results\nProduct.fetch(filter)","output":[{"items":[{"mime":"c3/notebook","value":["{","\t\"kind\": \"JSON\",","\t\"output\": {","\t\t\"data\": {","\t\t\t\"objs\": [","\t\t\t\t{","\t\t\t\t\t\"id\": \"prod_002\",","\t\t\t\t\t\"name\": \"Organic Cotton T-Shirt\",","\t\t\t\t\t\"meta\": {","\t\t\t\t\t\t\"appCode\": 1865745090558541600,","\t\t\t\t\t\t\"env\": \"srinat\",","\t\t\t\t\t\t\"app\": \"academyfundamentals\",","\t\t\t\t\t\t\"created\": \"2026-05-21T18:22:26Z\",","\t\t\t\t\t\t\"createdBy\": \"sriram.natarajan@c3.ai\",","\t\t\t\t\t\t\"updated\": \"2026-05-21T19:08:37Z\",","\t\t\t\t\t\t\"updatedBy\": \"sriram.natarajan@c3.ai\",","\t\t\t\t\t\t\"timestamp\": \"2026-05-21T19:08:37Z\",","\t\t\t\t\t\t\"fetchInclude\": \"[]\",","\t\t\t\t\t\t\"fetchType\": \"Product\"","\t\t\t\t\t},","\t\t\t\t\t\"version\": 2,","\t\t\t\t\t\"description\": \"100% organic cotton crew neck t-shirt available in multiple colors\",","\t\t\t\t\t\"category\": \"Clothing\",","\t\t\t\t\t\"unitPric