d City\",","\t\t\t\t\t\t\"meta\": {","\t\t\t\t\t\t\t\"appCode\": 1865745090558541600,","\t\t\t\t\t\t\t\"env\": \"srinat\",","\t\t\t\t\t\t\t\"app\": \"academyfundamentals\",","\t\t\t\t\t\t\t\"created\": \"2026-05-21T18:11:15Z\",","\t\t\t\t\t\t\t\"createdBy\": \"sriram.natarajan@c3.ai\",","\t\t\t\t\t\t\t\"updated\": \"2026-05-21T18:14:09Z\",","\t\t\t\t\t\t\t\"updatedBy\": \"sriram.natarajan@c3.ai\",","\t\t\t\t\t\t\t\"timestamp\": \"2026-05-21T18:14:09Z\",","\t\t\t\t\t\t\t\"fetchInclude\": \"[]\",","\t\t\t\t\t\t\t\"fetchType\": \"City\"","\t\t\t\t\t\t},","\t\t\t\t\t\t\"version\": 3,","\t\t\t\t\t\t\"population\": 84292,","\t\t\t\t\t\t\"salesTaxRate\": 9.875","\t\t\t\t\t},","\t\t\t\t\t\"cells\": [","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"RWC\",","\t\t\t\t\t\t\t\"source\": \"RWC\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"Redwood City\",","\t\t\t\t\t\t\t\"source\": \"Redwood City\"","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"84,292\",","\t\t\t\t\t\t\t\"source\": 84292","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"9.875\",","\t\t\t\t\t\t\t\"source\": 9.875","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"{…}\",","\t\t\t\t\t\t\t\"source\": {","\t\t\t\t\t\t\t\t\"appCode\": 1865745090558541600,","\t\t\t\t\t\t\t\t\"env\": \"srinat\",","\t\t\t\t\t\t\t\t\"app\": \"academyfundamentals\",","\t\t\t\t\t\t\t\t\"created\": \"2026-05-21T18:11:15Z\",","\t\t\t\t\t\t\t\t\"createdBy\": \"sriram.natarajan@c3.ai\",","\t\t\t\t\t\t\t\t\"updated\": \"2026-05-21T18:14:09Z\",","\t\t\t\t\t\t\t\t\"updatedBy\": \"sriram.natarajan@c3.ai\",","\t\t\t\t\t\t\t\t\"timestamp\": \"2026-05-21T18:14:09Z\",","\t\t\t\t\t\t\t\t\"fetchInclude\": \"[]\",","\t\t\t\t\t\t\t\t\"fetchType\": \"City\"","\t\t\t\t\t\t\t}","\t\t\t\t\t\t},","\t\t\t\t\t\t{","\t\t\t\t\t\t\t\"string\": \"3\",","\t\t\t\t\t\t\t\"source\": 3","\t\t\t\t\t\t}","\t\t\t\t\t]","\t\t\t\t}","\t\t\t],","\t\t\t\"isDataGridValues\": false","\t\t}","\t},","\t\"settings\": {","\t\t\"privateFields\": false,","\t\t\"maxHeight\": 540,","\t\t\"gridRows\": 100,","\t\t\"theme\": \"Default Dark Modern\"","\t}","}"]}]}],"executionSummary":{"timing":{"startTime":1779387791466,"endTime":1779387793148},"executionOrder":15,"success":true}},{"kind":2,"languageId":"javascript","value":"// Return the number of persisted City records\nCity.fetchCount()","output":[{"items":[{"mime":"text/plain","value":["2"]}]}],"executionSummary":{"timing":{"startTime":1779387802327,"endTime":1779387802395},"executionOrder":16,"success":true}},{"kind":1,"languageId":"markdown","value":"You can configure a `fetch` with the `FetchSpec` Type. You pass in the configuration options as an argument to the fetch call.","output":[],"executionSummary":{}},{"kind":2,"languageId":"javascript","value":"// Uncomment the following line to display the FetchSpec documentation\nFetchSpec\n","output":[{"items":[{"mime":"c3/notebook","value":["{","\t\"kind\": \"TYPEDOC\",","\t\"output\": {","\t\t\"appName\": \"academyfundamentals\",","\t\t\"endpoint\": \"http://stgawstrn1-srinat-c3-k8ssvc-appleader-001:8888/srinat/academyfundamentals\",","\t\t\"typeName\": \"FetchSpec\",","\t\t\"kind\": \"TYPE\",","\t\t\"privateFields\": false,","\t\t\"maxHeight\": 540,","\t\t\"gridRows\": 100,","\t\t\"theme\": \"Default Dark Modern\",","\t\t\"html\": \"<div id=\\\"type:FetchSpec\\\" class=\\\"structure type root\\\">\\n<h1 class=\\\"type root\\\">Type <span class=\\\"name\\\">FetchSpec</span></h1>\\n<p class=\\\"description\\\">Specification of which Objs to bring back and which fields to bring back in them for a <a class=\\\"method documentation\\\" data-to-id=\\\"method:Persistable.fetch\\\" title=\\\"method Persistable#fetch\\\" href=\\\"#METHOD#Persistable#fetch\\\">Persistable#fetch</a> call.</p>\\n<div class=\\\"mixes\\\"><p>Mixes:</p>\\n<ul class=\\\"mixes\\\">\\n<li class=\\\"mixes\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchSpecBase\\\" title=\\\"type FetchSpecBase\\\" href=\\\"#TYPE#FetchSpecBase\\\">FetchSpecBase</a></li>\\n<li class=\\\"mixes\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpec\\\" title=\\\"type FetchFilterSpec\\\" href=\\\"#TYPE#FetchFilterSpec\\\">FetchFilterSpec</a></li>\\n</ul></div>\\n<p class=\\\"use collapsed\\\">Used by 12 types</p><div class=\\\"use expanded\\\"><p>Used by:</p>\\n<ul class=\\\"use expanded\\\">\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:App.Alert.FetchSpec.Ui\\\" title=\\\"type App.Alert.FetchSpec.Ui\\\" href=\\\"#TYPE#App.Alert.FetchSpec.Ui\\\">App.Alert.FetchSpec.Ui</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:ArtifactHub.DependencyResolutionSpec\\\" title=\\\"type ArtifactHub.DependencyResolutionSpec\\\" href=\\\"#TYPE#ArtifactHub.DependencyResolutionSpec\\\">ArtifactHub.DependencyResolutionSpec</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:ArtifactHub.FetchSpec\\\" title=\\\"type ArtifactHub.FetchSpec\\\" href=\\\"#TYPE#ArtifactHub.FetchSpec\\\">ArtifactHub.FetchSpec</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:ArtifactHub.FetchSpecBase\\\" title=\\\"type ArtifactHub.FetchSpecBase\\\" href=\\\"#TYPE#ArtifactHub.FetchSpecBase\\\">ArtifactHub.FetchSpecBase</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:Data.SparkFetchSpec\\\" title=\\\"type Data.SparkFetchSpec\\\" href=\\\"#TYPE#Data.SparkFetchSpec\\\">Data.SparkFetchSpec</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:DataLake.Catalog.TableSpec\\\" title=\\\"type DataLake.Catalog.TableSpec\\\" href=\\\"#TYPE#DataLake.Catalog.TableSpec\\\">DataLake.Catalog.TableSpec</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchArrowStreamSpec\\\" title=\\\"type FetchArrowStreamSpec\\\" href=\\\"#TYPE#FetchArrowStreamSpec\\\">FetchArrowStreamSpec</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchStreamSpec\\\" title=\\\"type FetchStreamSpec\\\" href=\\\"#TYPE#FetchStreamSpec\\\">FetchStreamSpec</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:MultiLocaleFetchSpec\\\" title=\\\"type MultiLocaleFetchSpec\\\" href=\\\"#TYPE#MultiLocaleFetchSpec\\\">MultiLocaleFetchSpec</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:PerfMetricRawMetricsSpec\\\" title=\\\"type PerfMetricRawMetricsSpec\\\" href=\\\"#TYPE#PerfMetricRawMetricsSpec\\\">PerfMetricRawMetricsSpec</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:SearchFetchQuerySpec\\\" title=\\\"type SearchFetchQuerySpec\\\" href=\\\"#TYPE#SearchFetchQuerySpec\\\">SearchFetchQuerySpec</a></li>\\n<li class=\\\"use expanded\\\"><a class=\\\"type documentation\\\" data-to-id=\\\"type:Workflow.Monitorable.SummarySpec\\\" title=\\\"type Workflow.Monitorable.SummarySpec\\\" href=\\\"#TYPE#Workflow.Monitorable.SummarySpec\\\">Workflow.Monitorable.SummarySpec</a></li>\\n</ul></div>\\n<h2 class=\\\"section field-section\\\">Fields</h2>\\n<div id=\\\"field:FetchSpec.offset\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">offset</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:IntType\\\" title=\\\"primitive int\\\" href=\\\"#TYPE#IntType\\\">int</a></h3>\\n<p class=\\\"description\\\">Offset to use for paged reads.</p>\\n<p class=\\\"initializer\\\">Default: <code>0</code></p></div>\\n<div id=\\\"field:FetchSpec.limit\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">limit</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:IntType\\\" title=\\\"primitive int\\\" href=\\\"#TYPE#IntType\\\">int</a></h3>\\n<div class=\\\"description\\\">\\n<p>Maximum number of Objs to return (starting from <a class=\\\"field documentation\\\" data-to-id=\\\"field:FetchSpec.offset\\\" title=\\\"field FetchSpec#offset\\\" href=\\\"#FIELD#FetchSpec#offset\\\">offset</a>).  If there are fewer rows than were requested, only\\nthose will be returned.  If there are additional rows beyond what was requested, then <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchResult.hasMore\\\" title=\\\"type FetchResult.hasMore\\\" href=\\\"#TYPE#FetchResult.hasMore\\\">FetchResult.hasMore</a>\\nwill be set to true.</p>\\n<p>-1 returns all.</p>\\n</div>\\n<p class=\\\"initializer\\\">Default: <code>2000</code></p></div>\\n<div id=\\\"field:FetchSpec.include\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">include</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a></h3>\\n<div class=\\\"description\\\">\\n<p>Specifies which fields to bring back values for in the returned Obj instances.  Include specifications are\\nlogically a list of field paths.  The following examples illustrate the supported ways to specify them:</p>\\n<ul>\\n<li>\\n<p>Simple list of fields - \\\"[field1, field2, field3]\\\"</p>\\n</li>\\n<li>\\n<p>List of fields involving references and non-reference fields - \\\"[refField1.name, refField1.refField2.name]\\\"</p>\\n</li>\\n<li>\\n<p>Same as above with Obj notation - \\\"[{refField1: [name, {refField2: [name]}]}]\\\"</p>\\n</li>\\n<li>\\n<p>Using array/mapp '[index/key]' references</p>\\n<p>[arrayField[1]] - Array element with key '1'</p>\\n<p>[mappField['k1']] - Mapp element with key 'k1'</p>\\n<p>[fkeyArrayField[1] - Fkey array element at offset '1'</p>\\n<p>[arrayField[1].(name == 'foo')] Array element with key '1' if it matches name filter</p>\\n<p>[arrayField.(name == 'foo')[1]] array element with offset '1' that matches name filter</p>\\n<p>[fkeyField.(offset() == 0 &amp;&amp; limit() == 3)] offset/limit applied to fkey</p>\\n<p>[fkeyField.(pos() &gt;= 0 &amp;&amp; pos() &lt; 3)] alternate way to specify offset/limit applied to fkey</p>\\n</li>\\n<li>\\n<p>Return all fields in obj - Either not specified or \\\"[this]\\\"  Note that for external references, only the ids are\\nreturned unless an explicit include indicates that data from the reference should be returned (see below).\\nAlso, fkey fields (e.g. fields defined like arry: SomeType(fkeyField)) are also only brought back if specifically\\nincluded.</p>\\n</li>\\n<li>\\n<p>Using dot query to filter arry/mapp results - \\\"[refArry.(name == 'foo')]\\\" or \\\"[{refArry: [id]}.(name == 'foo')]\\\"</p>\\n</li>\\n</ul>\\n</div>\\n</div>\\n<div id=\\\"field:FetchSpec.excludeMeta\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">excludeMeta</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h3>\\n<p class=\\\"description\\\">The <code>meta</code> field is included by default when fetching data.  Set this to true to avoid it from being included.\\nThis can reduce the i/o for fetching large amounts of data when the <code>meta</code> isn't required.</p>\\n</div>\\n<div id=\\\"field:FetchSpec.includeReadCalcs\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">includeReadCalcs</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h3>\\n<p class=\\\"description\\\">If true, then all read calcs will be returned by default (including for any included child refs that specify\\nthe default include), if false, only those specifically requested via the <code>include</code> will be returned.</p>\\n</div>\\n<div id=\\\"field:FetchSpec.refreshCalcFields\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">refreshCalcFields</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h3>\\n<p class=\\\"description\\\">Flag indicating that any stored calc fields being returned are calculated to have up to date values as part of this\\nrequest.  This should only be used if up to date data is absolutely required and there is the possibility, due to\\nasynchronous processing delay of stored calc fields, that they may not be up to date.</p>\\n</div>\\n<div id=\\\"field:FetchSpec.calcFieldsToRefresh\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">calcFieldsToRefresh</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:Array<string>\\\" title=\\\"array collection\\\" href=\\\"#TYPE#Array&lt;string&gt;\\\">[</a> <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> ] <span class=\\\"attributes\\\"><span class=\\\"not persistable\\\">not persistable</span></span></h3>\\n<p class=\\\"description\\\">List of stored calc fields to recalculate.  Ignored if <a class=\\\"field documentation\\\" data-to-id=\\\"field:FetchSpec.refreshCalcFields\\\" title=\\\"field FetchSpec#refreshCalcFields\\\" href=\\\"#FIELD#FetchSpec#refreshCalcFields\\\">refreshCalcFields</a> is false.  If\\n<a class=\\\"field documentation\\\" data-to-id=\\\"field:FetchSpec.refreshCalcFields\\\" title=\\\"field FetchSpec#refreshCalcFields\\\" href=\\\"#FIELD#FetchSpec#refreshCalcFields\\\">refreshCalcFields</a> is true and this is not specified, then all stored calc fields will be recalculated.</p>\\n</div>\\n<div id=\\\"field:FetchSpec.explain\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">explain</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h3>\\n<p class=\\\"description\\\">Flag to request generation of the query plan in addition to returning the data.  Can be used for performance\\nanalysis, etc.</p>\\n</div>\\n<div id=\\\"field:FetchSpec.validateOnly\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">validateOnly</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h3>\\n<p class=\\\"description\\\">Flag indicating that the input parameters should all be validated (including database syntax error checking) and\\nthe query plan should be generated but not data should be retrieved from the database or returned.  Useful for\\nvalidating filter/include syntax and doing preventive performance analysis without actually issuing database\\nqueries.</p>\\n</div>\\n<div id=\\\"field:FetchSpec.hints\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">hints</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchHints\\\" title=\\\"type FetchHints\\\" href=\\\"#TYPE#FetchHints\\\">FetchHints</a></h3>\\n<p class=\\\"description\\\">Caller controllable hints to alter the way that queries are generated/executed in a fetch call.  Hints will\\nNEVER change the returned results.</p>\\n</div>\\n<div id=\\\"field:FetchSpec.useSecondaryDatastore\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">useSecondaryDatastore</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h3>\\n<p class=\\\"description\\\">If true, the fetch will be done from the secondary datastore for the type.  If no secondary datastore is defined\\nan exception will be thrown.  If the fetch references types that don't have a secondary datastore defined, the\\nbehavior will be the same as if those types without a secondary datastore (or one that doesn't match) were in\\na facaded tenant/tag.</p>\\n</div>\\n<div id=\\\"field:FetchSpec.resolveRefTypes\\\" class=\\\"structure field\\\">\\n<h3><span class=\\\"name\\\">resolveRefTypes</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h3>\\n<div class=\\\"description\\\">\\n<p>By default, entity references retrieved via <a class=\\\"type documentation\\\" data-to-id=\\\"type:Persistable.fetch\\\" title=\\\"type Persistable.fetch\\\" href=\\\"#TYPE#Persistable.fetch\\\">Persistable.fetch</a> and <a class=\\\"type documentation\\\" data-to-id=\\\"type:Persistable.get\\\" title=\\\"type Persistable.get\\\" href=\\\"#TYPE#Persistable.get\\\">Persistable.get</a> only include the\\n<code>id</code> of the reference, unless additional fields in the referenced type are added as part of the include spec.\\nAlso, for references to extended/parametric types, the returned instances will have the type of the the field's\\nreference type, rather than the concrete type of the actual instances themselves.</p>\\n<p>If this flag is set to true, then those instances will be of the correct concrete type if they aren't already.\\nNote that this requires additional queries/joins (up to 1 for each referenced field) so it should only be used when\\nhaving the instances of the concrete type is necessary.</p>\\n</div>\\n</div>\\n<h2 class=\\\"section field-section inherited\\\">Fields from FetchSpecBase</h2>\\n<div id=\\\"field:FetchSpec.order\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">order</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> <span class=\\\"attributes\\\"><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<div class=\\\"description\\\">\\n<p>Specifies the order to return Objs.  Default if not specified is by \\\"id\\\".</p>\\n<p>Supports multiple fields (e.g. \\\"field1, field2\\\") and descending order per field (e.g. \\\"field1, descending(field2)\\\").</p>\\n<p>If <a class=\\\"field documentation\\\" data-to-id=\\\"field:FetchSpec.limit\\\" title=\\\"field FetchSpec#limit\\\" href=\\\"#FIELD#FetchSpec#limit\\\">limit</a> is set to -1, and order is specified as \\\"&lt;none&gt;\\\", then no order will be applied at the database.\\nThis should only be done if its impact is fully understood as it may help performance in some cases and hurt it in\\nothers.  If you aren't sure, DON'T USE IT.</p>\\n</div>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchSpecBase\\\" title=\\\"type FetchSpecBase\\\" href=\\\"#TYPE#FetchSpecBase\\\">FetchSpecBase</a></p>\\n</div>\\n<h2 class=\\\"section field-section inherited\\\">Fields from FetchFilterSpec</h2>\\n<div id=\\\"field:FetchSpec.fetchHiddenSeedData\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">fetchHiddenSeedData</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Flag indicating that the normal suppression of hidden seed data should not be applied.  Only used internally for\\nproper seed data handling.  For types that do not mixin SeedData, this is ignored.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpec\\\" title=\\\"type FetchFilterSpec\\\" href=\\\"#TYPE#FetchFilterSpec\\\">FetchFilterSpec</a></p>\\n</div>\\n<div id=\\\"field:FetchSpec.excludeExtensions\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">excludeExtensions</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Flag indicating that only Obj instances that are extension types of the requested type should not be returned.\\nFor example, if FixedAsset.fetch is called with this option, then Objs of type Facility, etc. will not be returned.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpec\\\" title=\\\"type FetchFilterSpec\\\" href=\\\"#TYPE#FetchFilterSpec\\\">FetchFilterSpec</a></p>\\n</div>\\n<div id=\\\"field:FetchSpec.asOf\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">asOf</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:DateTimeType\\\" title=\\\"primitive datetime\\\" href=\\\"#TYPE#DateTimeType\\\">datetime</a> <span class=\\\"attributes\\\"><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Timed fetch parameter to limit all requested arrys with a reference type of either TimedValueHistory or TimedRelation\\nto return only the values that were effective at that time.  This should not be specified along with <a class=\\\"field documentation\\\" data-to-id=\\\"field:FetchSpec.timeRange\\\" title=\\\"field FetchSpec#timeRange\\\" href=\\\"#FIELD#FetchSpec#timeRange\\\">timeRange</a>.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpec\\\" title=\\\"type FetchFilterSpec\\\" href=\\\"#TYPE#FetchFilterSpec\\\">FetchFilterSpec</a></p>\\n</div>\\n<div id=\\\"field:FetchSpec.allowLiteralOnBindVariableOverflow\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">allowLiteralOnBindVariableOverflow</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">If true and the maximum number of bind variables has been reached for the query, additional values will be added\\nto the query as literal values, quoted and escaped as necessary.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpec\\\" title=\\\"type FetchFilterSpec\\\" href=\\\"#TYPE#FetchFilterSpec\\\">FetchFilterSpec</a></p>\\n</div>\\n<div id=\\\"field:FetchSpec.useDedicatedConnection\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">useDedicatedConnection</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">If true, a dedicated connection will be used for the operation.  Otherwise, a shared read connection may be\\nused.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpec\\\" title=\\\"type FetchFilterSpec\\\" href=\\\"#TYPE#FetchFilterSpec\\\">FetchFilterSpec</a></p>\\n</div>\\n<div id=\\\"field:FetchSpec.stmtTimeoutMs\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">stmtTimeoutMs</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:IntType\\\" title=\\\"primitive int\\\" href=\\\"#TYPE#IntType\\\">int</a> <span class=\\\"attributes\\\"><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<div class=\\\"description\\\">\\n<p>When set to something &gt; 0 and there is a backing db that supports it, the timeout for operations/statements on\\nthe connection used will be set with this timeout value.  Note that this will apply to all child actions\\n(synchronous only) that occur as part of the action this is called on.  Also note this applies to the execution of\\nthe query itself and does not apply to total time used to read/process the entire result set or processing child\\nqueries.</p>\\n<p>Note that this will be ignored for any backing datastore that does not support it.</p>\\n</div>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpec\\\" title=\\\"type FetchFilterSpec\\\" href=\\\"#TYPE#FetchFilterSpec\\\">FetchFilterSpec</a></p>\\n</div>\\n<div id=\\\"field:FetchSpec.dontThrowJsonDeserErrors\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">dontThrowJsonDeserErrors</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">If an error occurs deserializing a persisted json value for a value type that accepts either string (or boxed\\nstring), the error text will be returned as the value.  If the value type doesn't accept either string (or boxed\\nstring) and this is true, null will be returned as the value, otherwise an exception will be thrown.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpec\\\" title=\\\"type FetchFilterSpec\\\" href=\\\"#TYPE#FetchFilterSpec\\\">FetchFilterSpec</a></p>\\n</div>\\n<div id=\\\"field:FetchSpec.includeBaseTypes\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">includeBaseTypes</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpec\\\" title=\\\"type FetchFilterSpec\\\" href=\\\"#TYPE#FetchFilterSpec\\\">FetchFilterSpec</a></p>\\n</div>\\n<h2 class=\\\"section field-section inherited\\\">Fields from FetchFilterSpecBase</h2>\\n<div id=\\\"field:FetchSpec.filter\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">filter</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> <span class=\\\"attributes\\\"><span class=\\\"serialized\\\">serialized</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<div class=\\\"description\\\">\\n<p>Filter expression for which Obj instances to return.  Filter expressions must evaluate to a value type of\\nBoolean.  They support basic comparison operators (e.g. \\\"==\\\", \\\"&lt;\\\", \\\"&lt;=\\\", \\\"&gt;\\\", \\\"&gt;=\\\", \\\"!=\\\"), arithmetic operators\\n(e.g. \\\"+\\\", \\\"-\\\", \\\"*\\\", \\\"/\\\"), \\\"&amp;&amp;\\\", \\\"||\\\" and \\\"most\\\" non-timeseries functions supported by the C3 expression engine.</p>\\n<p>Expressions can include fields in the Obj itself (e.g. \\\"name == 'foo'\\\"), as well as fields in Objs in other\\ntypes referenced from the Obj (e.g. \\\"refField.name == 'foo'\\\").  Expressions involving arry/mapp fields will\\nautomatically be interpreted as \\\"exists\\\" queries (e.g. \\\"refArry.name == 'foo'\\\" will bring back all Obj instances\\nthat have at least one entry in refArry where the referenced Obj has the value 'foo' for its name field).</p>\\n</div>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpecBase\\\" title=\\\"type FetchFilterSpecBase\\\" href=\\\"#TYPE#FetchFilterSpecBase\\\">FetchFilterSpecBase</a></p>\\n<p class=\\\"serialized\\\">Serialized <a class=\\\"type documentation\\\" data-to-id=\\\"type:Filter\\\" title=\\\"type Filter\\\" href=\\\"#TYPE#Filter\\\">Filter</a></p>\\n</div>\\n<div id=\\\"field:FetchSpec.vars\\\" class=\\\"structure field inherited\\\">\\n<h3><span class=\\\"name\\\">vars</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:Map<string,_Obj>\\\" title=\\\"map collection\\\" href=\\\"#TYPE#Map&lt;string, Obj&gt;\\\">map</a>&lt;string, <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a>&gt; <span class=\\\"attributes\\\"><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Variables values to substitute in filter expression. CURRENTLY UNDER CONSTRUCTION!</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchFilterSpecBase\\\" title=\\\"type FetchFilterSpecBase\\\" href=\\\"#TYPE#FetchFilterSpecBase\\\">FetchFilterSpecBase</a></p>\\n</div>\\n<h2 class=\\\"section method-section\\\">Methods</h2>\\n<div id=\\\"method:FetchSpec.withIdFilter\\\" class=\\\"structure method\\\">\\n<h3><span class=\\\"name\\\">withIdFilter</span>(id): mixing <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchSpec\\\" title=\\\"type FetchSpec\\\" href=\\\"#TYPE#FetchSpec\\\">FetchSpec</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span></span></h3>\\n<p class=\\\"description\\\">Adds snippet \\\"id == &lt;id&gt;\\\" to the filter</p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">id</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span><span class=\\\"non-empty\\\">non-empty</span></span>\\n<p class=\\\"description\\\">Id to filter for.</p>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns mixing <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchSpec\\\" title=\\\"type FetchSpec\\\" href=\\\"#TYPE#FetchSpec\\\">FetchSpec</a></h4>\\n<p class=\\\"description\\\">updated FetchSpec</p>\\n</div></div>\\n<div id=\\\"method:FetchSpec.withIdsFilter\\\" class=\\\"structure method\\\">\\n<h3><span class=\\\"name\\\">withIdsFilter</span>(ids): mixing <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchSpec\\\" title=\\\"type FetchSpec\\\" href=\\\"#TYPE#FetchSpec\\\">FetchSpec</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span></span></h3>\\n<p class=\\\"description\\\">Adds snippet \\\"intersects(id, [&lt;ids&gt;])\\\" to the filter</p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">ids</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:Array<string>\\\" title=\\\"array collection\\\" href=\\\"#TYPE#Array&lt;string&gt;\\\">[</a> <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> ] <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span></span>\\n<p class=\\\"description\\\">Ids to filter for.</p>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns mixing <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchSpec\\\" title=\\\"type FetchSpec\\\" href=\\\"#TYPE#FetchSpec\\\">FetchSpec</a></h4>\\n<p class=\\\"description\\\">updated FetchSpec</p>\\n</div></div>\\n<div id=\\\"method:FetchSpec.withIdRangeFilter\\\" class=\\\"structure method\\\">\\n<h3><span class=\\\"name\\\">withIdRangeFilter</span>(startId, endId): mixing <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchSpec\\\" title=\\\"type FetchSpec\\\" href=\\\"#TYPE#FetchSpec\\\">FetchSpec</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span></span></h3>\\n<p class=\\\"description\\\">Adds id range snippet to the filter</p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter optional\\\"><span class=\\\"name\\\">startId</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a>\\n<p class=\\\"description\\\">If not null, start of id range.</p>\\n</li>\\n<li class=\\\"parameter optional\\\"><span class=\\\"name\\\">endId</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a>\\n<p class=\\\"description\\\">If not null, end of id range.</p>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns mixing <a class=\\\"type documentation\\\" data-to-id=\\\"type:FetchSpec\\\" title=\\\"type FetchSpec\\\" href=\\\"#TYPE#FetchSpec\\\">FetchSpec</a></h4>\\n<p class=\\\"description\\\">updated FetchSpec</p>\\n</div></div>\\n<div id=\\\"method:FetchSpec.quoteValue\\\" class=\\\"structure method\\\">\\n<h3><span class=\\\"name\\\">quoteValue</span>(value): <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> <span class=\\\"attributes\\\"><span class=\\\"static\\\">static</span></span></h3>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter optional\\\"><span class=\\\"name\\\">value</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:AnyType\\\" title=\\\"any\\\" href=\\\"#TYPE#AnyType\\\">any</a>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> <span class=\\\"attributes\\\"><span class=\\\"non-empty\\\">non-empty</span></span></h4>\\n<p class=\\\"description\\\">quoted representation of the value that is safe to be used in C3 expressions.</p>\\n</div></div>\\n<h2 class=\\\"section method-section inherited\\\">Methods from Obj</h2>\\n<div id=\\\"method:FetchSpec.type\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">type</span>(): <a class=\\\"type documentation\\\" data-to-id=\\\"type:Type\\\" title=\\\"type Type\\\" href=\\\"#TYPE#Type\\\">Type</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">C3 Type of this instance.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:Type\\\" title=\\\"type Type\\\" href=\\\"#TYPE#Type\\\">Type</a> <span class=\\\"attributes\\\"><span class=\\\"non-empty\\\">non-empty</span></span></h4>\\n</div></div>\\n<div id=\\\"method:FetchSpec.instanceOf\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">instanceOf</span>(typeName): <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"overloaded\\\">overloaded</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Checks whether this Obj is an instance of the specified type by checking both its type and the mixin chain.\\nThis is the most convenient way to ask \\\"is this type usable in a context requiring the other type?\\\"</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">typeName</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span><span class=\\\"non-empty\\\">non-empty</span></span>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h4>\\n<p class=\\\"description\\\">true if this instance is of this type or any of its mixins</p>\\n</div></div>\\n<div id=\\\"method:FetchSpec.instanceOf-2\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">instanceOf</span>(type): <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"overloaded\\\">overloaded</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Checks whether this instance is an instance of the specified type by checking both its type and the mixin chain.\\nThis is the most convenient way to ask \\\"is this type usable in a context requiring the other type?\\\"</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">type</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:Type\\\" title=\\\"type Type\\\" href=\\\"#TYPE#Type\\\">Type</a> <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span><span class=\\\"non-empty\\\">non-empty</span></span>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h4>\\n<p class=\\\"description\\\">true if this instance is of this type or any of its mixins</p>\\n</div><p class=\\\"see\\\">See <a class=\\\"method documentation\\\" data-to-id=\\\"method:ValueType.isA\\\" title=\\\"method ValueType#isA\\\" href=\\\"#METHOD#ValueType#isA\\\">ValueType#isA</a></p>\\n</div>\\n<div id=\\\"method:FetchSpec.isEmptyObj\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">isEmptyObj</span>(): <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Whether all the fields of this instance are empty.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h4>\\n</div></div>\\n<div id=\\\"method:FetchSpec.isSame\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">isSame</span>(other): <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Whether the specified instance represents exactly the same object as this instance.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">other</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a> <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span></span>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h4>\\n</div></div>\\n<div id=\\\"method:FetchSpec.isFieldSet\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">isFieldSet</span>(field): <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"overloaded\\\">overloaded</span><span class=\\\"final\\\">final</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Used to determine if a field is set. A field is set if a value was provided for that field to a constructor, or\\nif the field value set the its default value by the constructor. A set field is never missing.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">field</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span><span class=\\\"non-empty\\\">non-empty</span></span>\\n<p class=\\\"description\\\">the field to check</p>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h4>\\n<p class=\\\"description\\\">whether the specified field is set</p>\\n</div></div>\\n<div id=\\\"method:FetchSpec.isFieldSet-2\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">isFieldSet</span>(field): <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"overloaded\\\">overloaded</span><span class=\\\"final\\\">final</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Used to determine if a field is set. A field is set if a value was provided for that field to a constructor, or\\nif the field value set the its default value by the constructor. A set field is never missing.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">field</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:FieldType\\\" title=\\\"type FieldType\\\" href=\\\"#TYPE#FieldType\\\">FieldType</a> <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span><span class=\\\"non-empty\\\">non-empty</span></span>\\n<p class=\\\"description\\\">the field to check</p>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h4>\\n<p class=\\\"description\\\">whether the specified field is set</p>\\n</div></div>\\n<div id=\\\"method:FetchSpec.isFieldMissing\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">isFieldMissing</span>(field): <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"overloaded\\\">overloaded</span><span class=\\\"final\\\">final</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Used to determine if a field is missing. The value of a missing field is not known, so a missing field's value\\nshould not be used. For example, when <a class=\\\"method documentation\\\" data-to-id=\\\"method:Fetchable.fetch\\\" title=\\\"method Fetchable#fetch\\\" href=\\\"#METHOD#Fetchable#fetch\\\">fetching</a> an entity, a field that is not\\n<a class=\\\"type documentation\\\" data-to-id=\\\"type:Include\\\" title=\\\"type Include\\\" href=\\\"#TYPE#Include\\\">included</a> in the fetch is missing. Accessing a missing field will yield an empty value.\\nA missing field is never set.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">field</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span><span class=\\\"non-empty\\\">non-empty</span></span>\\n<p class=\\\"description\\\">the field to check</p>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h4>\\n<p class=\\\"description\\\">whether the specified field is missing</p>\\n</div></div>\\n<div id=\\\"method:FetchSpec.isFieldMissing-2\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">isFieldMissing</span>(field): <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"overloaded\\\">overloaded</span><span class=\\\"final\\\">final</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Used to determine if a field is missing. The value of a missing field is not known, so a missing field's value\\nshould not be used. For example, when <a class=\\\"method documentation\\\" data-to-id=\\\"method:Fetchable.fetch\\\" title=\\\"method Fetchable#fetch\\\" href=\\\"#METHOD#Fetchable#fetch\\\">fetching</a> an entity, a field that is not\\n<a class=\\\"type documentation\\\" data-to-id=\\\"type:Include\\\" title=\\\"type Include\\\" href=\\\"#TYPE#Include\\\">included</a> in the fetch is missing. Accessing a missing field will yield an empty value.\\nA missing field is never set.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">field</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:FieldType\\\" title=\\\"type FieldType\\\" href=\\\"#TYPE#FieldType\\\">FieldType</a> <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span><span class=\\\"non-empty\\\">non-empty</span></span>\\n<p class=\\\"description\\\">the field to check</p>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a></h4>\\n<p class=\\\"description\\\">whether the specified field is missing</p>\\n</div></div>\\n<div id=\\\"method:FetchSpec.fieldValue\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">fieldValue</span>(field, defaultToEmpty): <em>T</em> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"overloaded\\\">overloaded</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Returns value of the given field.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">field</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:StringType\\\" title=\\\"primitive string\\\" href=\\\"#TYPE#StringType\\\">string</a> <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span></span>\\n<p class=\\\"description\\\">Field to return the value for\\ndefaultToEmpty\\nwill return default empty value if field is missing</p>\\n</li>\\n<li class=\\\"parameter optional\\\"><span class=\\\"name\\\">defaultToEmpty</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <em>T</em></h4>\\n</div></div>\\n<div id=\\\"method:FetchSpec.fieldValue-2\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">fieldValue</span>(field, defaultToEmpty): <em>T</em> <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"overloaded\\\">overloaded</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Returns value of the given field type. Be sure to use the FieldType instance for the exact same type as the type of\\nthe obj.</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter required\\\"><span class=\\\"name\\\">field</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:FieldType\\\" title=\\\"type FieldType\\\" href=\\\"#TYPE#FieldType\\\">FieldType</a> <span class=\\\"attributes\\\"><span class=\\\"required\\\">required</span></span>\\n<p class=\\\"description\\\">Field to return the value for\\ndefaultToEmpty\\nwill return default empty value if field is missing</p>\\n</li>\\n<li class=\\\"parameter optional\\\"><span class=\\\"name\\\">defaultToEmpty</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <em>T</em></h4>\\n<p class=\\\"description\\\">value for the given field</p>\\n</div></div>\\n<div id=\\\"method:FetchSpec.fieldValues\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">fieldValues</span>(): <a class=\\\"type documentation\\\" data-to-id=\\\"type:Array<FieldValue>\\\" title=\\\"array collection\\\" href=\\\"#TYPE#Array&lt;FieldValue&gt;\\\">[</a> <a class=\\\"type documentation\\\" data-to-id=\\\"type:FieldValue\\\" title=\\\"type FieldValue\\\" href=\\\"#TYPE#FieldValue\\\">FieldValue</a> ] <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Returns all non empty field values. Note that it is recommended to use <a class=\\\"method documentation\\\" data-to-id=\\\"method:FetchSpec.eachFieldValue\\\" title=\\\"method FetchSpec#eachFieldValue\\\" href=\\\"#METHOD#FetchSpec#eachFieldValue\\\">#eachFieldValue</a> instead</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:Array<FieldValue>\\\" title=\\\"array collection\\\" href=\\\"#TYPE#Array&lt;FieldValue&gt;\\\">[</a> <a class=\\\"type documentation\\\" data-to-id=\\\"type:FieldValue\\\" title=\\\"type FieldValue\\\" href=\\\"#TYPE#FieldValue\\\">FieldValue</a> ]</h4>\\n</div></div>\\n<div id=\\\"method:FetchSpec.fieldValuesByOrdinal\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">fieldValuesByOrdinal</span>(skipTrailingEmpty): <a class=\\\"type documentation\\\" data-to-id=\\\"type:Array<any>\\\" title=\\\"array collection\\\" href=\\\"#TYPE#Array&lt;any&gt;\\\">[</a> <a class=\\\"type documentation\\\" data-to-id=\\\"type:AnyType\\\" title=\\\"any\\\" href=\\\"#TYPE#AnyType\\\">any</a> ] <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Returns all field values including empty ones as array where value of a field is at corresponding ordinal position.\\nUnless <code>skipTrailingEmpty</code> parameter is set and there are trailing empty values resulting array has same size as\\n#dataFieldTypes</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"parameters\\\"><h4>Parameters:</h4>\\n<ol>\\n<li class=\\\"parameter optional\\\"><span class=\\\"name\\\">skipTrailingEmpty</span>: <a class=\\\"type documentation\\\" data-to-id=\\\"type:BooleanType\\\" title=\\\"primitive boolean\\\" href=\\\"#TYPE#BooleanType\\\">boolean</a>\\n</li>\\n</ol></div>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:Array<any>\\\" title=\\\"array collection\\\" href=\\\"#TYPE#Array&lt;any&gt;\\\">[</a> <a class=\\\"type documentation\\\" data-to-id=\\\"type:AnyType\\\" title=\\\"any\\\" href=\\\"#TYPE#AnyType\\\">any</a> ]</h4>\\n</div></div>\\n<div id=\\\"method:FetchSpec.fieldValuesByFieldType\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">fieldValuesByFieldType</span>(): <a class=\\\"type documentation\\\" data-to-id=\\\"type:Map<FieldType,_any>\\\" title=\\\"map collection\\\" href=\\\"#TYPE#Map&lt;FieldType, any&gt;\\\">map</a>&lt;FieldType, <a class=\\\"type documentation\\\" data-to-id=\\\"type:AnyType\\\" title=\\\"any\\\" href=\\\"#TYPE#AnyType\\\">any</a>&gt; <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Returns all non empty field values by field type. Note that it is recommended to use <a class=\\\"method documentation\\\" data-to-id=\\\"method:FetchSpec.eachFieldValue\\\" title=\\\"method FetchSpec#eachFieldValue\\\" href=\\\"#METHOD#FetchSpec#eachFieldValue\\\">#eachFieldValue</a> instead</p>\\n<p class=\\\"inherited-from\\\">Inherited from <a class=\\\"type documentation\\\" data-to-id=\\\"type:Obj\\\" title=\\\"type Obj\\\" href=\\\"#TYPE#Obj\\\">Obj</a></p>\\n<div class=\\\"returns\\\"><h4>Returns <a class=\\\"type documentation\\\" data-to-id=\\\"type:Map<FieldType,_any>\\\" title=\\\"map collection\\\" href=\\\"#TYPE#Map&lt;FieldType, any&gt;\\\">map</a>&lt;FieldType, <a class=\\\"type documentation\\\" data-to-id=\\\"type:AnyType\\\" title=\\\"any\\\" href=\\\"#TYPE#AnyType\\\">any</a>&gt;</h4>\\n</div></div>\\n<div id=\\\"method:FetchSpec.fieldValuesByFieldName\\\" class=\\\"structure method inherited\\\">\\n<h3><span class=\\\"name\\\">fieldValuesByFieldName</span>(): <a class=\\\"type documentation\\\" data-to-id=\\\"type:Map<string,_any>\\\" title=\\\"map collection\\\" href=\\\"#TYPE#Map&lt;string, any&gt;\\\">map</a>&lt;string, <a class=\\\"type documentation\\\" data-to-id=\\\"type:AnyType\\\" title=\\\"any\\\" href=\\\"#TYPE#AnyType\\\">any</a>&gt; <span class=\\\"attributes\\\"><span class=\\\"member\\\">member</span><span class=\\\"inherited\\\">inherited</span></span></h3>\\n<p class=\\\"description\\\">Returns all non empty